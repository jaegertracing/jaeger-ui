#!/usr/bin/env sh

# Husky commit-msg hook: installed and managed via "husky install" (e.g., from npm run prepare)

# Get the signature line
NAME=$(git config user.name)
EMAIL=$(git config user.email)

# Abort if we don't have a valid NAME or EMAIL
if [ -z "$NAME" ] || [ -z "$EMAIL" ]; then
    echo "ERROR: Git user.name and/or user.email are not configured; cannot add DCO sign-off." >&2
    echo "Please configure them, for example:" >&2
    echo "  git config --global user.name \"Your Name\"" >&2
    echo "  git config --global user.email \"you@example.com\"" >&2
    exit 1
fi
SIG="Signed-off-by: $NAME <$EMAIL>"

# Check if it's already there to avoid duplicates
if ! grep -q "$SIG" "$1"; then
    # Append a newline and the signature in a portable way
    printf '\n%s\n' "$SIG" >> "$1"
fi


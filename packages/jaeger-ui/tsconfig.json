{
  "extends": "../../tsconfig",
  "compilerOptions": {
    "jsx": "react-jsx",
    "isolatedModules": false,
    "noEmit": true,
    "types": ["vitest/globals"],
    "paths": {
      "@jaegertracing/plexus": ["../plexus/src/index.ts"],
      "@jaegertracing/plexus/lib/*": ["../plexus/src/*"]

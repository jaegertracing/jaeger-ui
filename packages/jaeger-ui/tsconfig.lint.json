// This file is used for type-checking (tsc-lint). It differs from tsconfig.json in two ways:
// 1. isolatedModules: false — Vite requires isolatedModules: true, but full cross-file
//    type checking (e.g. const enums, exhaustive type narrowing) requires false.
// 2. noEmit: true — type-check only; paths in tsconfig.json resolve @jaegertracing/plexus
//    imports directly to source, so no compilation output is needed or expected.
{
  "extends": "./tsconfig",
  "compilerOptions": {
    "isolatedModules": false,
    "noEmit": true
  },
  "files": [
    "src/components/App/index.tsx",
    "src/components/DependencyGraph/index.tsx",
    "src/components/SearchTracePage/index.tsx",
    "src/components/SearchTracePage/SearchForm.tsx",
    "src/components/SearchTracePage/SearchResults/ScatterPlot.tsx",
    "src/components/DependencyGraph/sample_data/large.json",
    "src/components/DependencyGraph/sample_data/small.json",
    "package.json"
  ]
}

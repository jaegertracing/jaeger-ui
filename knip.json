{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/**/*.{js,ts,cjs}"],
      "ignoreDependencies": [
        "@emnapi/core",
        "@emnapi/runtime",
        "@noble/hashes",
        "@tanstack/react-virtual",
        "@testing-library/dom",
        "@vitest/coverage-v8",
        "@babel/core",
        "depcheck",
        "eslint-plugin-react-x",
        "react-side-effect",
        "vitest"
      ]
    },
    "packages/jaeger-ui": {
      "ignore": ["src/demo/**", "src/utils/DraggableManager/demo/**"],
      "ignoreDependencies": ["identity-obj-proxy"]
    },
    "packages/plexus": {
      "ignore": ["demo/**", "src/input.fixture.tsx"],
      "ignoreDependencies": ["antd", "identity-obj-proxy"]
    }
  }
}
